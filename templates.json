{
  "version": "1.0",
  "templates": [
    {
      "id": "T_JPP_ROOMING",
      "name": "JPP 루밍표",
      "priority": 30,
      "detect": {
        "keywords": ["JPP", "루밍", "룸조인"],
        "minMatches": 2
      },
      "fields": {}
    },
    {
      "id": "T_AGENCY_FULL_LIST",
      "name": "여행사 전체명단",
      "priority": 25,
      "detect": {
        "keywords": ["전체명단", "전체 명단", "탑승객 명단", "전체인원"],
        "minMatches": 1
      },
      "fields": {}
    },
    {
      "id": "T_CHAMJOEUN_PDF_CONFIRM",
      "name": "참좋은여행 확정서",
      "priority": 40,
      "detect": {
        "keywords": ["참좋은여행", "참좋은", "확정서"],
        "minMatches": 2
      },
      "inherits": "T_GENERIC_TRAVEL",
      "fields": {
        "agency": {
          "label": "여행사",
          "knownValues": ["참좋은여행", "참좋은"],
          "patterns": [],
          "transform": "trim"
        }
      }
    },
    {
      "id": "T_GENERIC_TRAVEL",
      "name": "일반 여행확정서",
      "priority": 10,
      "detect": {
        "keywords": ["확정서", "여행일정", "출발일", "행사기간", "여행기간"],
        "minMatches": 2
      },
      "fields": {
        "depDate": {
          "label": "출발일",
          "patterns": [
            "^기간\\s+(\\d{1,2})\\/(\\d{1,2})\\/\\d{2,4}",
            "(?:제\\s*1\\s*일|1일차)[^\\d]*(\\d{1,2})\\/(\\d{1,2})",
            "(?:출발일[자:\\s]*|출발:\\s*|일정:\\s*)(\\d{1,2}[.\\/\\-]\\d{1,2})",
            "(?:행사기간|여행기간)[^\\d]*(?:\\d{4}\\s+)?(\\d{1,2})[\\/\\-](\\d{1,2})\\s*[~\\-～]",
            "\\b\\d{4}-(\\d{2})-(\\d{2})(?:\\s+\\d{2}:\\d{2}:\\d{2})?",
            "(\\d{1,2}월\\s*\\d{1,2}일)"
          ],
          "transform": "dateNormalize"
        },
        "destination": {
          "label": "여행지",
          "patterns": [
            "(?:여행지|목적지|행선지)[:\\s　]+([가-힣A-Za-z\\s]+)"
          ],
          "fallback": "jpDestinationScan",
          "transform": "trimFirst"
        },
        "duration": {
          "label": "기간",
          "patterns": [
            "(?:기간|여행기간|일정)\\s*[:\\s　]*(\\d+박\\s*\\d+일|\\d+일|\\d+N\\d+D)",
            "(\\d+박\\s*\\d+일|\\d+일간)"
          ],
          "fallback": "durationFromRange",
          "transform": "durationNormalize"
        },
        "agency": {
          "label": "여행사",
          "knownValues": [
            "하나투어", "모두투어", "노랑풍선", "참좋은여행", "참좋은",
            "롯데관광개발", "롯데관광", "교원투어", "한진관광",
            "레드캡투어", "세중여행", "세중", "현대드림투어",
            "인터파크트리플", "인터파크투어", "마이리얼트립",
            "온라인투어", "야놀자", "여기어때", "내일투어",
            "내일여행", "여행박사", "혜초여행", "팜투어",
            "유니드파트너스", "국일여행사", "온누리투어", "자유투어",
            "투어2000", "롯데JTB", "세계로여행", "갤럭시아투어",
            "참투어", "우리투어", "KRT", "SM C&C", "타이드스퀘어"
          ],
          "patterns": [
            "(?:ATTN|수신|TO)\\s*:?\\s*([가-힣A-Za-z0-9\\s&]+?)(?:\\s*\\/|\\s*담당|\\s*부서|\\s*과장|\\s*팀장|\\s*이사|$)",
            "(?:여행사|주관|담당)[:\\s　]+([가-힣A-Za-z0-9\\s]+)"
          ],
          "transform": "trimSlice30"
        },
        "flightOut": {
          "label": "출국편",
          "patterns": [
            "(?:출국편|출국항공|출발편|항공편)[:\\s　]*([A-Z]{2}\\s*\\d{3,4}[A-Z]?)",
            "([A-Z0-9]{2}\\d{3,4})\\s*[\\(（][^)]*(?:한국|인천)\\s*출발"
          ],
          "transform": "flightNormalize"
        },
        "flightIn": {
          "label": "귀국편",
          "patterns": [
            "(?:귀국편|귀국항공|귀국)[:\\s　]*([A-Z]{2}\\s*\\d{3,4}[A-Z]?)"
          ],
          "transform": "flightNormalize"
        },
        "meetingTime": {
          "label": "미팅시간",
          "patterns": [
            "(?:미팅|집합|모임|집결|가이드\\s*미팅)[^\\d]*(\\d{1,2}:\\d{2}|\\d{1,2}시\\s*\\d{0,2}분?)",
            "(?:미팅|집합|모임|집결|가이드\\s*미팅).*?(\\d{1,2}:\\d{2})(?!\\d)"
          ],
          "transform": "timeNormalize"
        },
        "meetingPlace": {
          "label": "미팅장소",
          "knownValues": [
            "인천국제공항", "인천 국제공항", "인천공항",
            "김포공항", "김해국제공항", "김해공항",
            "제주국제공항", "제주공항", "청주공항",
            "대구공항", "광주공항", "무안공항"
          ],
          "patterns": [
            "(?:미팅|집합|모임|집결|가이드\\s*미팅).*?((?:인천국제공항|인천공항|김포공항|김해국제공항|김해공항|제주국제공항|제주공항|청주공항|대구공항|광주공항|무안공항)[가-힣A-Za-z0-9\\s\\-·\\/]*)",
            "(?:미팅장소|집합장소|집합위치|만남위치|집결장소|가이드\\s*미팅)[:\\s　]+([가-힣A-Za-z0-9\\s\\-·]+)"
          ],
          "transform": "trimSlice60"
        },
        "hotelName": {
          "label": "호텔명",
          "patterns": [
            "^\\[H\\]\\s*([가-힣A-Za-z0-9\\s\\-·]+?)(?:\\s+T\\.\\s*\\d|\\s*\\/|$)",
            "호텔\\s*:\\s*([가-힣A-Za-z0-9\\s\\-·\\.]+?)(?:\\s*[\\(（][\\d\\-]+[\\)）]|$)",
            "(?:호텔명|hotel\\s*name)[:\\s　]*([가-힣A-Za-z0-9\\s\\-·]+)"
          ],
          "transform": "hotelNameClean"
        },
        "hotelPhone": {
          "label": "호텔전화",
          "patterns": [
            "(?:호텔\\s*(?:전화|연락처|TEL|tel))[:\\s　]*([+\\d\\-\\s]{7,25})",
            "호텔\\s*:\\s*[가-힣A-Za-z0-9\\s\\-·\\.]+?[\\(（]([\\d\\-]{7,20})[\\)）]"
          ],
          "transform": "trim"
        }
      }
    }
  ]
}
